APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# URL absolut (route(), webhook DOKU) selalu memakai APP_URL ini, meskipun browser membuka 127.0.0.1 — lihat AppServiceProvider.
# Set APP_URL ke URL publik https://… (penting untuk link DOKU / notifikasi / webhook Moota).
# Proxy (Cloudflare, nginx): trust proxies selalu aktif di bootstrap/app.php.
# Uji penerimaan webhook: POST {APP_URL}/webhooks/test (tanpa CSRF).
APP_TIMEZONE=Asia/Jakarta
CONTACT_US_PHONE=
CONTACT_US_WHATSAPP=

# Booking: batas H-X sebelum tanggal mulai layanan (refund / reschedule)
BOOKING_REFUND_MIN_DAYS_BEFORE_SERVICE=60
BOOKING_RESCHEDULE_MIN_DAYS_BEFORE_SERVICE=30

# Setelah hari layanan terakhir (ends_on) lewat: jeda menit dari 00:00 hari berikutnya (APP_TIMEZONE) lalu auto selesaikan layanan jika jamaah belum klik
BOOKING_AUTO_COMPLETE_GRACE_MINUTES_AFTER_DAY=1
# Rating 1–5 untuk penyelesaian otomatis (tanpa rating manual)
BOOKING_AUTO_COMPLETE_DEFAULT_RATING=5

# Admin keuangan: berapa bulan terakhir yang dimuat untuk tabel riwayat (kartu ringkasan tetap seluruh data)
# ADMIN_FINANCE_HISTORY_MONTHS=24

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Log alur pembayaran ([payment] di laravel.log). Matikan di production jika terlalu ramai.
PAYMENT_FLOW_LOG=true

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=baytgo
DB_USERNAME=root
DB_PASSWORD=

# Akun admin (seeder) — pakai alamat Gmail Anda
ADMIN_EMAIL=yourname@gmail.com
ADMIN_PASSWORD=password
ADMIN_NAME=Administrator BaytGo

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Log Viewer (admin): /logs — hanya role admin
LOG_VIEWER_ENABLED=true

# log = tanpa WebSocket; reverb = realtime (wajib `php artisan reverb:start`)
BROADCAST_CONNECTION=log
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_SERVER_HOST=127.0.0.1
# REVERB_SERVER_PORT=8080
# REVERB_HOST="${REVERB_SERVER_HOST}"
# REVERB_PORT="${REVERB_SERVER_PORT}"
# REVERB_SCHEME=http
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

FONNTE_TOKEN=
FONNTE_OTP_ENABLED=true
FONNTE_API_URL=https://api.fonnte.com/send
FONNTE_COUNTRY_CODE=62
# ISO 3166-1 alpha-2: interpretasi nomor tanpa prefiks + (contoh format lokal 08… untuk Indonesia).
PHONE_DEFAULT_REGION=ID

FONNTE_BOOKING_NOTIFY_ENABLED=true
FONNTE_PAYMENT_NOTIFY_ENABLED=true
FONNTE_CUSTOMER_BOOKING_APPROVED_NOTIFY_ENABLED=true
# Insiden — broadcast WA ke muthowif lain (peluang menggantikan) saat rekrutmen dibuka
FONNTE_INCIDENT_REPLACEMENT_OPPORTUNITY_NOTIFY_ENABLED=true
# Insiden — WA ke jamaah saat pool pengganti siap dipilih
FONNTE_INCIDENT_CUSTOMER_REPLACEMENT_POOL_NOTIFY_ENABLED=true

# Midtrans Snap (pembayaran booking)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_CORE_PAYMENT_EXPIRE_MINUTES=60

# DOKU (pembayaran booking — Checkout + VA direct)
# Client ID di Back Office bisa berbentuk BRN-… atau MCH-… (sama-sama untuk API non-SNAP + Checkout).
# invalid_client_id di sandbox: biasanya Client ID/Secret yang dipakai adalah kredensial PRODUCTION → set DOKU_IS_PRODUCTION=true
#   atau minta/aktifkan pasangan SANDBOX di dashboard. Client ID dan Secret harus dari satu baris yang sama.
DOKU_CLIENT_ID=
DOKU_SECRET_KEY=
DOKU_IS_PRODUCTION=false
DOKU_PAYMENT_DUE_MINUTES=60
DOKU_VA_EXPIRE_MINUTES=60
DOKU_NOTIFICATION_PATH=/payments/doku/notification
DOKU_GOPAY_CHECKOUT_METHOD=EMONEY_DANA

# Halaman bayar booking customer: doku (Checkout/VA) atau moota (Create Transaction + webhook mutasi).
BOOKING_PAYMENT_DRIVER=doku

# Moota API v2 — https://api.moota.co
MOOTA_API_BASE_URL=https://api.moota.co
MOOTA_API_EMAIL=
MOOTA_API_PASSWORD=
# ID rekening Moota untuk Create Transaction — satu nilai, atau beberapa (pisahkan koma). Satu request API hanya boleh satu ID.
MOOTA_BANK_ACCOUNT_ID=
# Jika lebih dari satu ID: halaman bayar web menampilkan satu opsi per rekening. first|round_robin|user = fallback bila pemanggilan tanpa rekening terpilih (API/mobile).
MOOTA_BANK_ACCOUNT_PICK=first
MOOTA_PAYMENT_EXPIRE_MINUTES=1440
MOOTA_ACCESS_TOKEN_CACHE_MINUTES=55

# Whitelist IP pengirim webhook: config/services.php → moota.webhook_ips (bukan .env).
# Secret sama dengan rahasia webhook di dashboard Moota (HMAC-SHA256 atas raw body); kosongkan jika integrasi Signature belum diaktifkan
MOOTA_WEBHOOK_SIGNING_SECRET=

VITE_APP_NAME="${APP_NAME}"
