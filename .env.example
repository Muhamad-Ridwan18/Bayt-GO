APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta
CONTACT_US_PHONE=
CONTACT_US_WHATSAPP=

# Booking: batas H-X sebelum tanggal mulai layanan (refund / reschedule)
BOOKING_REFUND_MIN_DAYS_BEFORE_SERVICE=60
BOOKING_RESCHEDULE_MIN_DAYS_BEFORE_SERVICE=30

# Setelah hari layanan terakhir (ends_on) lewat: jeda menit dari 00:00 hari berikutnya (APP_TIMEZONE) lalu auto selesaikan layanan jika jamaah belum klik
BOOKING_AUTO_COMPLETE_GRACE_MINUTES_AFTER_DAY=1
# Rating 1–5 untuk penyelesaian otomatis (tanpa rating manual)
BOOKING_AUTO_COMPLETE_DEFAULT_RATING=5

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=baytgo
DB_USERNAME=root
DB_PASSWORD=

# Akun admin (seeder) — pakai alamat Gmail Anda
ADMIN_EMAIL=yourname@gmail.com
ADMIN_PASSWORD=password
ADMIN_NAME=Administrator BaytGo

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

FONNTE_TOKEN=
FONNTE_OTP_ENABLED=true
FONNTE_API_URL=https://api.fonnte.com/send
FONNTE_COUNTRY_CODE=62
FONNTE_BOOKING_NOTIFY_ENABLED=true
FONNTE_PAYMENT_NOTIFY_ENABLED=true
FONNTE_CUSTOMER_BOOKING_APPROVED_NOTIFY_ENABLED=true

# Midtrans Snap (pembayaran booking)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_CORE_PAYMENT_EXPIRE_MINUTES=60

# DOKU Checkout (pembayaran booking) — Client ID & Shared Key dari Back Office DOKU
DOKU_CHECKOUT_CLIENT_ID=
DOKU_CHECKOUT_SHARED_KEY=
DOKU_CHECKOUT_IS_SANDBOX=true
DOKU_CHECKOUT_PAYMENT_DUE_MINUTES=1440

VITE_APP_NAME="${APP_NAME}"
