{
  "info": {
    "name": "Moota API v2",
    "description": "Koleksi endpoint Moota (https://api.moota.co/). Whitelist IP webhook: 128.199.173.138",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.moota.co" },
    { "key": "token", "value": "" },
    { "key": "bank_id", "value": "" },
    { "key": "mutation_id", "value": "" },
    { "key": "webhook_id", "value": "" },
    { "key": "trx_id", "value": "" },
    { "key": "tag_id", "value": "" },
    { "key": "topup_id", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Generate Token (Login)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@moota.com\",\n  \"password\": \"password_account\",\n  \"scopes\": [\"api\"]\n}"
            },
            "url": "{{baseUrl}}/api/v2/auth/login"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v2/auth/logout"
          }
        },
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"moota\",\n  \"email\": \"moota@email.co\",\n  \"password\": \"your password\",\n  \"password_confirmation\": \"your password confirmation\"\n}"
            },
            "url": "{{baseUrl}}/api/v2/auth/register"
          }
        },
        {
          "name": "User Profile (GET)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v2/user"
          }
        },
        {
          "name": "Update User Profile (POST)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"loream\",\n  \"email\": \"user@example.com\",\n  \"no_ktp\": \"\",\n  \"alamat\": \"street 2373 Kelly Street\"\n}"
            },
            "url": "{{baseUrl}}/api/v2/user"
          }
        }
      ]
    },
    {
      "name": "Bank Accounts",
      "item": [
        {
          "name": "List Available Banks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v2/bank/available?page=1&per_page=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "bank", "available"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "My Bank Accounts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v2/bank?page=1&per_page=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "bank"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Create Bank Account",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"corporate_id\": \"\",\n  \"bank_type\": \"bca\",\n  \"username\": \"user_ibanking\",\n  \"password\": \"password_ibanking\",\n  \"name_holder\": \"Jhone Dhoe\",\n  \"account_number\": \"16899030\",\n  \"is_active\": true\n}"
            },
            "url": "{{baseUrl}}/api/v2/bank/store"
          }
        },
        {
          "name": "Update Bank Account",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"corporate_id\": \"\",\n  \"bank_type\": \"bca\",\n  \"username\": \"user_ibanking\",\n  \"password\": \"password_ibanking\",\n  \"name_holder\": \"Jhone Dhoe\",\n  \"account_number\": \"16899030\",\n  \"is_active\": true\n}"
            },
            "url": "{{baseUrl}}/api/v2/bank/update/{{bank_id}}"
          }
        },
        {
          "name": "Destroy Bank Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v2/bank/{{bank_id}}/destroy"
          }
        },
        {
          "name": "E-wallet Request OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v2/bank/request/otp/{{bank_id}}"
          }
        },
        {
          "name": "E-wallet Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp_code\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/v2/bank/verification/otp/{{bank_id}}"
          }
        },
        {
          "name": "Get Accounts Index (untuk Create Transaction)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v2/accounts/index"
          }
        },
        {
          "name": "Get Accounts (deprecated)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v2/accounts"
          }
        }
      ]
    },
    {
      "name": "Mutations",
      "item": [
        {
          "name": "Refresh Mutation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v2/bank/{{bank_id}}/refresh"
          }
        },
        {
          "name": "List Mutations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v2/mutation?type=&bank=&tag=&start_date=&end_date=&amount=&page=1&per_page=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "mutation"],
              "query": [
                { "key": "type", "value": "", "description": "CR|DB" },
                { "key": "bank", "value": "", "description": "bank_id" },
                { "key": "tag", "value": "" },
                { "key": "start_date", "value": "", "description": "Y-m-d" },
                { "key": "end_date", "value": "", "description": "Y-m-d" },
                { "key": "amount", "value": "" },
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Note Mutation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
