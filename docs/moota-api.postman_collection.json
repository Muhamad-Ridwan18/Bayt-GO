            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_id\": \"ORDER-001\",\n  \"account_id\": \"{{bank_id}}\",\n  \"customers\": {\n    \"name\": \"Jhon Doe\",\n    \"email\": null,\n    \"phone\": null\n  },\n  \"items\": [\n    {\n      \"name\": \"Air Mineral\",\n      \"description\": \"Air berkualitas\",\n      \"qty\": 1,\n      \"price\": 10000\n    }\n  ],\n  \"description\": \"Pembayaran pesanan\",\n  \"note\": null,\n  \"redirect_url\": \"https://www.example.com\",\n  \"success_redirect_url\": null,\n  \"failed_redirect_url\": null,\n  \"total\": 10000,\n  \"expired_in_minutes\": 60\n}"
