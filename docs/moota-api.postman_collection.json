            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"tabungan sekolah\"\n}"
            },
            "url": "{{baseUrl}}/api/v2/mutation/{{mutation_id}}/note"
          }
        },
        {
          "name": "Destroy Mutations (bulk)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mutations\": [\"mutation_id_1\", \"mutation_id_2\"]\n}"
            },
            "url": "{{baseUrl}}/api/v2/mutation/destroy"
          }
        },
        {
          "name": "Mutation Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v2/mutation/summary?bank_id=&type=&start_date=&end_date=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "mutation", "summary"],
              "query": [
                { "key": "bank_id", "value": "" },
                { "key": "type", "value": "", "description": "credit|debit" },
                { "key": "start_date", "value": "", "description": "Y-m-d GMT+7" },
                { "key": "end_date", "value": "", "description": "Y-m-d GMT+7" }
              ]
            }
          }
        }
      ]
    },
