{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://staging.baytgo.id/api",
        "EXPO_PUBLIC_WEB_URL": "https://staging.baytgo.id",
        "EXPO_PUBLIC_REVERB_HOST": "staging.baytgo.id",
        "EXPO_PUBLIC_REVERB_PORT": "443",
        "EXPO_PUBLIC_REVERB_SCHEME": "https"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
